@model List<ASC.Model.Domain.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Service Requests</h1>
            <p class="text-muted mb-0">Service request data loaded from the database.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-bordered table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Id</th>
                        <th>Customer Name</th>
                        <th>Vehicle Number</th>
                        <th>Service Type</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.CustomerName</td>
                                <td>@item.VehicleNumber</td>
                                <td>@item.ServiceType</td>
                                <td>@item.Status</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">No service requests found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>